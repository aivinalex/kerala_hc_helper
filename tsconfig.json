{
  "compilerOptions": {
    "target": "ES2020",
    "module": "NodeNext",

    "rootDir": "./src",
    "outDir": "./",

    "strict": true,

    "allowJs": false,
    "checkJs": false,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext"
  },
  "include": ["src"],
  "exclude": ["node_modules", "backend"]
}
