{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",

    "rootDir": "./src",
    "outDir": "./public",

    "strict": true,

    "allowJs": false,
    "checkJs": false,

    "esModuleInterop": true,
    "skipLibCheck": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "backend"]
}
